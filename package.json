{
  "name": "create-vex-app",
  "version": "1.1.1",
  "private": false,
  "type": "module",
  "description": "A monorepo template with Vite React frontend, HonoJS backend, and shared lib package",
  "license": "MIT",
  "author": "Alex Richards <alexchristopherrichards@gmail.com>",
  "homepage": "https://www.vexapp.io",
  "engines": {
    "bun": ">=1.2.21"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/acrichards3/create-vex-app.git"
  },
  "bugs": {
    "url": "https://github.com/acrichards3/create-vex-app/issues"
  },
  "keywords": [
    "template",
    "monorepo",
    "react",
    "vite",
    "hono",
    "bun",
    "typescript"
  ],
  "bin": {
    "create-vex-app": "bin/index.ts"
  },
  "files": [
    "bin",
    "scripts",
    ".github",
    "backend/src",
    "backend/drizzle.config.ts",
    "backend/tsconfig.drizzle.json",
    "backend/package.json",
    "backend/tsconfig.json",
    "backend/.eslintrc.cjs",
    "backend/.env.example",
    "frontend/src",
    "frontend/public",
    "frontend/index.html",
    "frontend/.env.example",
    "frontend/package.json",
    "frontend/vite.config.ts",
    "frontend/tailwind.config.js",
    "frontend/postcss.config.js",
    "frontend/tsconfig.json",
    "frontend/.eslintrc.cjs",
    "lib/src",
    "lib/package.json",
    "lib/tsconfig.json",
    "lib/.eslintrc.cjs",
    ".cursor",
    ".jscpd.json",
    "amplify.yml",
    "Dockerfile",
    ".dockerignore",
    ".prettierignore",
    ".prettierrc",
    ".gitignore",
    "LICENSE",
    "README.md",
    "tsconfig.json",
    "package.json"
  ],
  "workspaces": [
    "frontend",
    "lib",
    "backend"
  ],
  "scripts": {
    "build": "bun run build:lib && bun run typecheck && bun run lint && bun run build:frontend && bun run build:backend",
    "build:all": "bun run build:lib && bun run build:frontend && bun run build:backend",
    "build:backend": "bun run --filter @vex-app/backend build",
    "build:frontend": "bun run --filter @vex-app/frontend build",
    "build:lib": "bun run --filter @vex-app/lib build",
    "dev": "bun scripts/dev.ts",
    "dev:backend": "bun run --filter @vex-app/backend dev",
    "dev:frontend": "bun run --filter @vex-app/frontend dev",
    "dev:lib": "bun run --filter @vex-app/lib dev",
    "db:generate": "bun run --filter @vex-app/backend db:generate",
    "db:migrate": "bun run --filter @vex-app/backend db:migrate",
    "db:push": "bun run --filter @vex-app/backend db:push",
    "db:studio": "bun run --filter @vex-app/backend db:studio",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "bun run format:check && bun run lint:eslint",
    "lint:eslint": "bun run --filter '*' lint",
    "lint:fix": "bun run format && bun run --filter '*' lint --fix",
    "test": "bun test",
    "test:backend": "bun test --filter backend",
    "test:frontend": "bun test --filter frontend",
    "test:lib": "bun test --filter lib",
    "typecheck": "bun tsc -b --clean && bun tsc -b"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "eslint-plugin-sort-keys": "^2.3.5",
    "eslint-plugin-typescript-sort-keys": "^3.3.0",
    "prettier": "^3.2.5",
    "typescript": "^5.9.0"
  }
}
